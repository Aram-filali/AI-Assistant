# ==========================================
# Environment Variables (IMPORTANT!)
# ==========================================
# Block all .env files (development, testing, production)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local
.env.production
.env.staging
.env.test
.env.dev
*.env
**/.env
**/.env.*

# Keep .env.example (template for developers)
!.env.example
!backend/.env.example
!frontend/.env.example
!**/.env.example

# ==========================================
# Data & Logs (Keep dirs, ignore content)
# ==========================================

# Data files (keep structure only)
backend/data/uploads/*
backend/data/faiss_index/*.faiss
backend/data/faiss_index/*.pkl
backend/data/faiss_index/*.index

# Keep the directory markers (.gitkeep preserves empty dirs)
!backend/data/uploads/.gitkeep
!backend/data/faiss_index/.gitkeep
!backend/data/faiss_index/
!backend/data/uploads/

# Root data directories (structure only)
data/documents/*
data/faiss_index/*
data/logs/*
backups/*.sql
backups/*.dump
logs/
*.log

# Keep directories structure
!data/documents/.gitkeep
!data/faiss_index/.gitkeep
!data/logs/.gitkeep
!backups/.gitkeep

