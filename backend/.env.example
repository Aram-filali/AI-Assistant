# ------------------------------------------------------------------------------
# 🌍 ENVIRONMENT VARIABLES TEMPLATE
# ------------------------------------------------------------------------------
# Usage:
# 1. Copier ce fichier en .env
# 2. Remplir les valeurs secrètes
# 3. Ne jamais commiter .env sur Git
# ------------------------------------------------------------------------------

# --- APPLICATION ---
APP_NAME="AI Sales Assistant"
ENVIRONMENT="development"  # development, staging, production
DEBUG=true
SECRET_KEY="votre_secret_key_super_securisee_a_generer"
API_V1_STR="/api/v1"

# --- DATABASE (PostgreSQL) ---
# Format : postgresql://user:password@host:port/dbname
# Docker (interne) : postgresql://ai_sales_user:ai_sales_2024_secure@postgres:5432/ai_sales_db
# Localhost        : postgresql://ai_sales_user:ai_sales_2024_secure@localhost:5432/ai_sales_db
DATABASE_URL="postgresql://ai_sales_user:ai_sales_2024_secure@localhost:5432/ai_sales_db"

# --- CACHE (Redis) ---
# Format : redis://:password@host:port/db
# Docker (interne) : redis://:redis_password_2024@redis:6379/0
# Localhost        : redis://:redis_password_2024@localhost:6379/0
REDIS_URL="redis://:redis_password_2024@localhost:6379/0"

# --- SECURITY (JWT) ---
JWT_SECRET_KEY="votre_jwt_secret_key_a_changer"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORs ---
# Liste des origines autorisées (séparées par des virgules)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# --- EMAILS (Resend) ---
RESEND_API_KEY="re_123456789"
FROM_EMAIL="onboarding@resend.dev"
EMAIL_RESET_TOKEN_EXPIRE_HOURS=1

# --- AI SERVICES (OpenAI) ---
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_TEMPERATURE=0.7

# --- ZOOM INTEGRATION ---
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_ACCOUNT_ID=""
