# ==================== DATABASE ====================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Local development: postgresql://ai_sales_user:password@localhost:5432/ai_sales_db
# Production (Railway): provided automatically in DATABASE_URL environment variable
DATABASE_URL=postgresql://assistantuser:dev_password@localhost:5432/assistantdb

# ==================== REDIS ====================
# Redis connection for caching and sessions
# Local development: redis://localhost:6379/0
# Production (Railway): provided as REDIS_URL
REDIS_URL=redis://localhost:6379/0

# ==================== API SETTINGS ====================
# Application name displayed in API docs
APP_NAME=AI Sales Assistant

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (only in development!)
DEBUG=true

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Full API base URL (used in emails, redirects, etc.)
API_BASE_URL=http://localhost:8000

# ==================== SECURITY ====================
# Secret key for JWT token signing
# GENERATE with: python -c "import secrets; print(secrets.token_hex(32))"
# PRODUCTION: Must be a strong 32-character hex string stored in Railway Vault
SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890

# JWT algorithm (HS256 = HMAC with SHA-256, recommended for stateless microservices)
ALGORITHM=HS256

# Token expiration in minutes (24 hours = 1440 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== CORS ====================
# Comma-separated list of allowed origins for frontend requests
# PRODUCTION: update to your actual domain(s)
# Never use "*" in production (security risk)
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000

# ==================== AI/ML SERVICES ====================
# OpenAI API key (get from https://platform.openai.com/api-keys)
# Used for generating responses with company knowledge (RAG)
OPENAI_API_KEY=sk-...

# OpenAI model name
# Recommended: gpt-4 or gpt-4-turbo-preview
OPENAI_MODEL=gpt-4

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# PRODUCTION: use INFO or WARNING to reduce noise
LOG_LEVEL=INFO

# ==================== OPTIONAL: INTEGRATIONS ====================

# HumanLoop API key - for human-in-the-loop feedback system
# Get from: https://humanloop.com
HUMANLOOP_API_KEY=

# Email service (Resend)
# Get from: https://resend.com
RESEND_API_KEY=
FROM_EMAIL=noreply@assistant.local

# HubSpot CRM integration
# Get from: https://app.hubspot.com/upgrade/integrations/settings/apps/private-apps
HUBSPOT_API_KEY=

# ==================== TESTING ====================
# Test database URL (used by pytest)
# Usually a separate PostgreSQL instance or the same DB with test_ prefix
TEST_DATABASE_URL=postgresql://assistantuser:dev_password@localhost:5433/assistantdb_test

ZOOM_CLIENT_SECRET=""
ZOOM_ACCOUNT_ID=""
